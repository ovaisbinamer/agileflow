# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agileflow?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_string

# Frontend URL (used for CORS + invite links)
CLIENT_URL=http://localhost:5173

# Resend Email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
EMAIL_FROM=AgileFlow <noreply@yourdomain.com>

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxx
